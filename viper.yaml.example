snyk:
  token: ${SNYK_TOKEN}
  org: my-org

gitlab:
  url: https://gitlab.com
  token: ${VIPER_GITLAB_TOKEN}
  project_id: "12345"
  target_branch: main

ai:
  model: github_copilot/claude-sonnet-4.6
  temperature: 0.2
  max_tokens: 4096

agent:
  max_iterations: 40
  max_no_edit_iterations: 10
  timeout_per_tool: 300
  blocked_commands:
    - "rm -rf /"
    - "sudo"
    - "chmod"
    - "mkfs"
    - "npm audit"
    - "dd if="
    - "npm audit fix"
    - "npm update"
    - "yarn upgrade"
    - "pnpm up"

settings:
  severity_threshold: high
  dry_run: false
